# AdMaker reads keys from the browser (Settings panel) by default — nothing to set here.
# These are OPTIONAL server-side fallbacks so a deployed instance can run without each
# visitor pasting their own keys. Leave blank to force bring-your-own-key mode.
ANTHROPIC_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=

# Aspen (runonaspen.com) — a private, locally-run OpenAI-compatible model. When the
# key is set it runs the text steps (creative director, script, storyboard, brand,
# stills copy) in place of Claude. Base URL + model are optional (defaults shown).
ASPEN_API_KEY=
ASPEN_BASE_URL=https://my.runonaspen.com/v1
ASPEN_MODEL=qwen2.5:7b
